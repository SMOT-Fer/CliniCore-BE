# ===========================================
# LOCAL DEVELOPMENT (.env)
# ===========================================

# Database
DATABASE_URL=postgresql://postgres.lyddvcklsjslqkbzvzyf:SMOTFerDM21@aws-1-us-east-2.pooler.supabase.com:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Server
PORT=3001
NODE_ENV=development

# JWT (cambiar estos secrets en producción)
JWT_ACCESS_SECRET=replace_with_unique_access_secret_64_hex
JWT_REFRESH_SECRET=replace_with_unique_refresh_secret_64_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Frontend local en puerto 3000
CORS_ORIGINS=http://localhost:3000
CORS_STRICT=false

# Rate Limiting
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_AUTH_MAX=20
REQUEST_TIMEOUT_MS=15000
SESSION_IDLE_MINUTES=60
BCRYPT_SALT_ROUNDS=10

# API Externa
PERU_DEVS_API_KEY=cGVydWRldnMucHJvZHVjdGlvbi5maXRjb2RlcnMuNjk5MjVkMzQwNGEyNjc2MDk2ZjkzZDA1

# Frontend URL (para redirecciones OAuth)
FRONTEND_URL=http://localhost:3000

# Google OAuth (obtener en https://console.cloud.google.com/apis/credentials)
# Para desarrollo local, crear credenciales OAuth con:
# - Origenes autorizados: http://localhost:3000, http://localhost:3001
# - URIs de redireccion: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP para envío de emails (ejemplo con Gmail)
# Para Gmail: usar App Password desde https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CliniCore <noreply@clinicore.com>
