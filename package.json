{
  "name": "estudio",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --test tests/*.test.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "restart:pm2": "pm2 restart estudio-api",
    "logs:pm2": "pm2 logs estudio-api",
    "healthcheck": "node ops/healthcheck.js",
    "backup:db": "powershell -ExecutionPolicy Bypass -File ops/backup-postgres.ps1 -DatabaseUrl $env:DATABASE_URL",
    "setup:github": "powershell -ExecutionPolicy Bypass -File ops/github-setup.ps1",
    "migrate:up": "node ops/generate-db-config.js && db-migrate up",
    "migrate:down": "node ops/generate-db-config.js && db-migrate down",
    "migrate:create": "node ops/generate-db-config.js && db-migrate create --sql-file",
    "migrate:reset": "node ops/generate-db-config.js && db-migrate reset && npm run migrate:up"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
